# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Anthropic / CMA
ANTHROPIC_API_KEY=sk-ant-...
CMA_AGENT_ID=agent_...
CMA_ENVIRONMENT_ID=env_...
# Optional, comma-separated:
# CMA_VAULT_IDS=vault_a,vault_b
# CMA_MEMORY_STORE_ID=memstore_...

# Optional GitHub repo to mount into every new session's container.
# If CMA_GITHUB_REPO_URL is set, CMA_GITHUB_TOKEN is required.
# CMA_GITHUB_BRANCH and CMA_GITHUB_COMMIT are mutually exclusive (commit wins if both set).
# Token needs `Contents: read` on the repo.
# CMA_GITHUB_REPO_URL=https://github.com/owner/repo
# CMA_GITHUB_TOKEN=ghp_...
# CMA_GITHUB_BRANCH=main
# CMA_GITHUB_COMMIT=abc123
# CMA_GITHUB_MOUNT_PATH=/workspace/repo

# Server
DATABASE_PATH=./data/sessions.db
LOG_LEVEL=info
DAEMON_IDLE_TTL_SECONDS=1800
# Optional operator notification channel for posting failures:
# OPS_CHANNEL_ID=C0123456789
