# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Anthropic / CMA
ANTHROPIC_API_KEY=sk-ant-...
CMA_AGENT_ID=agent_...
CMA_ENVIRONMENT_ID=env_...
# Optional, comma-separated:
# CMA_VAULT_IDS=vault_a,vault_b
# CMA_MEMORY_STORE_ID=memstore_...

# Server
DATABASE_PATH=./data/sessions.db
LOG_LEVEL=info
DAEMON_IDLE_TTL_SECONDS=1800
# Optional operator notification channel for posting failures:
# OPS_CHANNEL_ID=C0123456789
